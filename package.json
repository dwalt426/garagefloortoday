  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test:links": "node scripts/check-links.mjs",
    "test:uniqueness": "node scripts/check-uniqueness.mjs",
    "test:a11y": "node scripts/check-a11y.mjs",
    "test:contrast": "node scripts/check-contrast.mjs",
    "test": "npm run typecheck && npm run test:links && npm run test:uniqueness && npm run test:a11y && npm run test:contrast",
    "analyze": "ANALYZE=true next build",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "next": "15.1.9",
    "react": "19.0.0",
    "react-dom": "19.0.0",
